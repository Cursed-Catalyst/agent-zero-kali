# ================================================================
#  Agent Zero - Environment Configuration
#  Kali Linux / No Docker Setup
#  Default model: Claude claude-sonnet-4-5
# ================================================================

# ── Anthropic API Key ───────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
API_KEY_ANTHROPIC=sk-ant-YOUR_KEY_HERE

# ── Other API keys (optional, leave blank if not using) ─────────
API_KEY_OPENAI=
API_KEY_GROQ=
API_KEY_GOOGLE=
API_KEY_MISTRAL=
API_KEY_PERPLEXITY=

# ── Web UI Settings ─────────────────────────────────────────────
WEB_UI_PORT=5000
WEB_UI_HOST=127.0.0.1

# ── Default Model (Claude claude-sonnet-4-5) ─────────────────────────
A0_CHAT_MODEL_PROVIDER=anthropic
A0_CHAT_MODEL_NAME=claude-sonnet-4-5
A0_UTILITY_MODEL_PROVIDER=anthropic
A0_UTILITY_MODEL_NAME=claude-sonnet-4-5

# ── Embedding model (local, no API key needed) ──────────────────
A0_EMBED_MODEL_PROVIDER=huggingface
A0_EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ── Code Execution (local shell on Kali, no Docker) ─────────────
# Agent Zero will use the local shell for code execution
# Be careful — Agent Zero has full access to your system!
